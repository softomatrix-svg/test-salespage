# Control Board API Skill - Environment Variables

# Required
CONTROLBOARD_API_TOKEN=your_token_here

# Workspace ID — get from GET /api/workspaces after connecting
# Required as X-Workspace-Id header for: Settings, Clips, Videos, Video Categories, Articles, Social Posts
CONTROLBOARD_WORKSPACE_ID=your_workspace_id_here

# Optional — stored per-workspace via POST /api/settings
# VIZARD_API_KEY=your_vizard_key_here
# VIZARD_PROJECT_ID=your_vizard_project_id_here
# LETTERMAN_API_KEY=your_letterman_key_here
# POSTBRIDGE_API_KEY=your_postbridge_key_here
